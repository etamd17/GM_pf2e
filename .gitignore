__pycache__/
*.pyc
.DS_Store
*.db-journal
venv/
.env

# Local-only Pathbuilder PC exports — used for verifying class progressions
# and calculation fixes. PCs reach the live site through the in-app
# JSON-upload + character-creator flow, NOT via the repo.
party_data/*.json
!party_data/portraits/

# GM-authored campaign intro metadata — local content, not repo state.
campaign.json

# Obsidian vault sync state — populated on the server's persistent
# volume by tools/push_vault.py; never committed.
vault_data/
.vault_last_push_ts
.vault_local_last_push_ts
obsidian_vault

# GM-uploaded campaign assets (splash images etc.) — server-local,
# never committed; lives on the Railway volume.
campaign_assets/

# Campaign audio — a symlink to the GM's local Foundry/audio folder (or a
# PF2E_AUDIO_DIR). Machine-specific, never committed.
campaign_audio
